{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["selections"],
  "additionalProperties": false,
  "properties": {
    "selections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc", "node_id"],
        "additionalProperties": false,
        "properties": {
          "doc": { "type": "string" },
          "node_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
