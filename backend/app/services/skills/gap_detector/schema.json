{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["gaps"],
  "additionalProperties": false,
  "properties": {
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "category", "severity"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["scope", "data", "security", "integration", "ux"] },
          "severity": { "type": "string", "enum": ["blocker", "major", "minor"] }
        }
      }
    }
  }
}
