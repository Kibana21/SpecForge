{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["functional_requirements", "non_functional_requirements", "constraints", "assumptions", "stakeholders"],
  "additionalProperties": false,
  "properties": {
    "functional_requirements": { "$ref": "#/$defs/requirement_array" },
    "non_functional_requirements": { "$ref": "#/$defs/requirement_array" },
    "constraints": { "$ref": "#/$defs/requirement_array" },
    "assumptions": { "$ref": "#/$defs/requirement_array" },
    "stakeholders": { "$ref": "#/$defs/requirement_array" }
  },
  "$defs": {
    "requirement_array": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "source_reference", "confidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string", "minLength": 1 },
          "source_reference": { "type": ["string", "null"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}
