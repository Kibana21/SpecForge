{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["facts"],
  "additionalProperties": false,
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "confidence", "source_fact_ids"],
        "properties": {
          "text": {"type": "string", "minLength": 5},
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "source_fact_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          }
        }
      }
    }
  }
}
