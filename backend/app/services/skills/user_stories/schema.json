{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["stories"],
  "additionalProperties": false,
  "properties": {
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptance_criteria", "story_points", "labels"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "story_points": { "type": "integer", "minimum": 1, "maximum": 13 },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
